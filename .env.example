DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id
# Whisper server endpoint. Set to your whisper.cpp server URL.
# The app container uses host networking, so localhost reaches the host directly.
WHISPER_ENDPOINT=http://localhost:8080
POSTGRES_PASSWORD=CHANGE_ME
RUST_LOG=info,serenity=warn,songbird=warn

# Docker Compose mounts host auth dirs to the app container: ~/.claude, ~/.local/share/opencode, ~/.cursor
# The following variables are set automatically by docker-compose.yml.
# When running outside Docker, uncomment and configure them.
# DATABASE_URL=postgresql://user:pass@localhost/discord_transcript
# Summary harness: claude (default) | cursor_agent | opencode
# SUMMARY_HARNESS=claude
# SUMMARY_COMMAND=/usr/local/bin/claude   # optional; overrides CLAUDE_COMMAND when set. Required for non-claude harnesses.
# CLAUDE_COMMAND=/usr/local/bin/claude    # required for claude harness when SUMMARY_COMMAND is unset
# CLAUDE_MODEL=haiku
# SUMMARY_MODEL=anthropic/claude-3-5-haiku-20241022   # optional; overrides CLAUDE_MODEL. Required for opencode.
# CHUNK_STORAGE_DIR points to the workspace root (workspaces/<guild>/<voice>/<meeting>/...).
# CHUNK_STORAGE_DIR=/var/data/chunks
# AUTO_STOP_GRACE_SECONDS=60
# WHISPER_LANGUAGE=ja
# WHISPER_BEAM_SIZE=5               # default: 5 (set to 1 for greedy/fastest)
# WHISPER_SUPPRESS_NON_SPEECH=true  # default: true
# WHISPER_PROMPT=                   # default: unset
# WHISPER_VAD=true                  # default: true
# WHISPER_TEMPERATURE=0.0           # default: 0.0 (deterministic decoding)
# WHISPER_RESAMPLE_TO_16K=true      # default: true
# PUBLIC_BASE_URL=https://transcripts.example.com
# WEB_PORT=3000
# WEB_BIND_HOST=127.0.0.1

# Discord OAuth (required for web authentication)
# Create at https://discord.com/developers/applications → OAuth2
# Add redirect URI: {PUBLIC_BASE_URL}/auth/callback
# DISCORD_CLIENT_ID=your_application_client_id
# DISCORD_CLIENT_SECRET=your_oauth2_client_secret
# WEB_SESSION_SECRET=random_secret_for_signing_cookies
